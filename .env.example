# Mode (CRITICAL - never set PAPER_TRADING=false without thorough testing)
PAPER_TRADING=true
BINANCE_TESTNET=true

# Binance
BINANCE_API_KEY=
BINANCE_SECRET=

# Database
DATABASE_URL=sqlite:///./trading_bot.db

# Redis (optional, for caching - Phase 3+)
REDIS_URL=redis://localhost:6379/0

# Webhook security (Phase 2)
WEBHOOK_SECRET=change_me_to_random_string

# Sentiment APIs (Phase 3, all optional)
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=trading_bot_v1

# Notifications (Phase 4, all optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# Server (Phase 2)
API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_PORT=8080

# Logging
LOG_LEVEL=INFO
